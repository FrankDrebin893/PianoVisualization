<UserControl x:Class="PianoMidiVisualizationApp.Views.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Border Background="#1A1A1A">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (always visible) -->
            <Border Grid.Row="0" Background="#252525" Padding="10,6" Cursor="Hand"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel>
                    <TextBlock Text="AI Music Assistant" Foreground="White" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Clear" Padding="8,2" Margin="0,0,8,0"
                                Command="{Binding ClearHistoryCommand}"
                                Visibility="{Binding IsPanelExpanded, Converter={StaticResource BoolToVisConverter}}"
                                Background="#333333" Foreground="#AAAAAA" BorderThickness="0" FontSize="11"/>
                        <TextBlock Foreground="#888888" FontSize="14" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#x25BC;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPanelExpanded}" Value="True">
                                            <Setter Property="Text" Value="&#x25B2;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="(Click to expand)"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPanelExpanded}" Value="True">
                                        <Setter Property="Text" Value=""/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConfigured}" Value="False">
                                        <Setter Property="Text" Value="(Set API key in settings to enable)"/>
                                        <Setter Property="Foreground" Value="#AA6600"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- Content (collapsible) -->
            <Border Grid.Row="1" Height="220"
                    Visibility="{Binding IsPanelExpanded, Converter={StaticResource BoolToVisConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Message history -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" x:Name="MessagesScrollViewer"
                                  Background="#111111" Padding="8">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="10,6" Margin="4,2" MaxWidth="500">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#303030"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Background" Value="#2B5278"/>
                                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                   Foreground="White" FontSize="13"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Error message -->
                    <Border Grid.Row="1" Background="#442222" Padding="8,4"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF8888" FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Input area -->
                    <Border Grid.Row="2" Background="#202020" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" x:Name="InputTextBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#2A2A2A" Foreground="White" BorderThickness="1"
                                     BorderBrush="#444444" Padding="8,6" FontSize="13"
                                     VerticalContentAlignment="Center"
                                     KeyDown="InputTextBox_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="IsEnabled" Value="True"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConfigured}" Value="False">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                <!-- Send button (shown when not loading) -->
                                <Button Content="Send" Padding="16,6"
                                        Command="{Binding SendCommand}"
                                        Background="#2B5278" Foreground="White" BorderThickness="0"
                                        FontWeight="SemiBold">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Cancel button (shown when loading) -->
                                <Button Content="Cancel" Padding="16,6"
                                        Command="{Binding CancelCommand}"
                                        Background="#664444" Foreground="White" BorderThickness="0"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
